# ===========================================
# 环境变量配置模板
# 请复制此文件为 .env.local 并填入实际值
# ===========================================

# Supabase 数据库配置（必需）
# 从 Supabase 项目设置 -> API 获取
COZE_SUPABASE_URL=https://your-project-id.supabase.co
COZE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Storage 配置（用于图片存储）
# 需要在 Supabase 中创建一个 public bucket
SUPABASE_STORAGE_BUCKET=product-images

# ===========================================
# 部署到 Vercel 时的配置说明：
# ===========================================
# 1. 在 Vercel 项目设置 -> Environment Variables 中添加以上变量
# 2. 确保在 Supabase 中创建了 storage bucket
# 3. 设置 bucket 为 public（公开访问）
